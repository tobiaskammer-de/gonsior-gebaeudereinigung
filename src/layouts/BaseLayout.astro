---
import '../styles/global.css';
import { company } from '../data/site.js';

const {
  title = `${company.name} ${company.city} — Sauberkeit, mit Handschlag.`,
  description = `Inhabergeführte Gebäudereinigung in ${company.city} und Umgebung. Glas-, Unterhalts-, Treppenhausreinigung und Sonderleistungen — verlässlich, freundlich, gründlich. ${company.hwk}.`,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = Astro.site ? new URL(base, Astro.site).toString() : '/';
const ogImage = `${base.replace(/\/$/, '')}/assets/hero-room.jpg`;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1f5f3e" />
  <link rel="icon" href={`${base.replace(/\/$/, '')}/assets/logo.jpg`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": company.name,
    "image": ogImage,
    "telephone": company.phoneIntl,
    "email": company.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": company.street,
      "postalCode": company.zip,
      "addressLocality": company.city,
      "addressCountry": "DE"
    },
    "areaServed": ["Essen","Mülheim an der Ruhr","Oberhausen","Gelsenkirchen"],
    "url": siteUrl,
    "sameAs": [company.instagramUrl]
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,500;8..60,600&family=Hanken+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip-link" href="#main">Zum Inhalt springen</a>
  <slot />
  <script src={`${base.replace(/\/$/, '')}/script.js`}></script>
</body>
</html>
