---
import { company } from '../data/site.js';
---
<section class="kontakt" id="kontakt">
  <div class="shell kontakt-shell">

    <div class="kontakt-text">
      <span class="kicker">§ 06 — Kontakt</span>
      <h2 class="section-title">
        Der einfachste Weg,<br/>
        <em>uns zu erreichen.</em>
      </h2>
      <p class="prose">
        Sie suchen eine professionelle Fachkraft für Glas-, Unterhalts-
        oder Treppenhausreinigung in {company.city} und Umgebung?
        Kontaktieren Sie uns per Anruf, WhatsApp oder E-Mail —
        {company.ownerFirst} {company.ownerLast} meldet sich innerhalb
        eines Werktags persönlich zurück.
      </p>
    </div>

    <div class="kontakt-grid">
      <a class="kontakt-card kontakt-call" href={`tel:${company.phoneIntl}`}>
        <span class="kc-eyebrow">Anrufen · Mo–Sa, 8–18 Uhr</span>
        <span class="kc-headline">{company.phone}</span>
        <span class="kc-foot">
          Direkt zu {company.ownerFirst} {company.ownerLast}
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

      <a class="kontakt-card" href={company.whatsappBase}>
        <span class="kc-eyebrow">WhatsApp</span>
        <span class="kc-headline">Nachricht schreiben</span>
        <span class="kc-foot">
          Fotos der Räume gerne mitschicken
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

      <a class="kontakt-card" href={`mailto:${company.email}?subject=Anfrage%20Geb%C3%A4udereinigung`}>
        <span class="kc-eyebrow">E-Mail</span>
        <span class="kc-headline">{company.email}</span>
        <span class="kc-foot">
          Antwort innerhalb eines Werktags
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>

      <div class="kontakt-card kontakt-card--meta" aria-label="Adresse">
        <span class="kc-eyebrow">Postanschrift</span>
        <span class="kc-headline kc-headline--small">{company.street}<br/>{company.zip} {company.city}</span>
        <span class="kc-foot kc-foot--quiet">
          {company.hwk}
        </span>
      </div>
    </div>

  </div>
</section>
