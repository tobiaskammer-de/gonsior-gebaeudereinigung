---
import { company } from '../data/site.js';

// LIVE INSTAGRAM FEED via Behold.so
// ---------------------------------
// Behold.so ist ein kostenloser Drittanbieter, der den Instagram-Feed
// lädt und alle paar Stunden automatisch aktualisiert. Kein API-Token,
// keine Wartung, kein Server.
//
// 2-Min-Setup (einmalig):
//   1) https://behold.so   → Sign up (kostenlos, kein Limit für 1 Feed)
//   2) "+ New Feed" → Instagram → euer Profil verbinden
//   3) Feed-ID kopieren (z. B. abcd1234-uvwx-5678)
//   4) Diese Variable im GitHub-Repo setzen:
//        Settings → Secrets and variables → Actions → Variables
//        → "New repository variable" → Name: BEHOLD_ID, Value: <Feed-ID>
//   5) Re-deploy (push oder "Run workflow") — fertig.
//
// Lokal entwickeln? Eine .env-Datei anlegen:
//        PUBLIC_BEHOLD_ID=eure-feed-id

const beholdId = import.meta.env.PUBLIC_BEHOLD_ID || '';
const hasLiveFeed = !!beholdId;
---
<section class="insta" id="insta">
  <div class="shell insta-shell">

    <header class="insta-head">
      <div class="insta-head-text">
        <span class="kicker">§ 05 — Instagram</span>
        <h2 class="section-title">
          Aus dem Arbeitsalltag.<br/>
          <em>@{company.instagram}.</em>
        </h2>
        <p class="section-lede">
          Kleine Eindrücke aus laufenden Aufträgen — gezeigt, wie es ist:
          ehrlich, mit dem Eimer in der Hand. Folgen Sie uns auf Instagram,
          wenn Sie ein Gefühl dafür wollen, wie wir arbeiten.
        </p>
      </div>
      <a class="btn btn-primary insta-cta" href={company.instagramUrl} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
        </svg>
        @{company.instagram} folgen
      </a>
    </header>

    {hasLiveFeed ? (
      <div class="insta-live">
        <div class="insta-live-strip">
          <span class="live-dot" aria-hidden="true"></span>
          <span class="live-label">Live-Feed</span>
          <span class="live-meta">Direkt aus dem Instagram-Profil — aktualisiert sich von selbst.</span>
        </div>
        <behold-widget feed-id={beholdId}></behold-widget>
        <script type="module" src="https://w.behold.so/widget.js" is:inline></script>
      </div>
    ) : (
      <div class="insta-fallback">
        <div class="insta-fallback-card">
          <div class="phone-frame" aria-hidden="true">
            <div class="phone-bar"><span></span></div>
            <div class="phone-screen">
              <div class="phone-profile">
                <div class="phone-avatar"></div>
                <div class="phone-handle">
                  <strong>@{company.instagram}</strong>
                  <span>Gonsior Gebäudereinigung · Essen</span>
                </div>
              </div>
              <div class="phone-grid">
                <div></div><div></div><div></div>
                <div></div><div></div><div></div>
              </div>
            </div>
          </div>
          <div class="insta-fallback-copy">
            <span class="kicker">Live-Feed bereit zum Aktivieren</span>
            <h3>Die letzten Posts erscheinen hier — sobald der Behold-Feed verbunden ist.</h3>
            <p>
              Behold.so ist kostenlos, dauert 2 Minuten zum Einrichten und holt
              den Feed alle paar Stunden frisch nach. Bis dahin verlinken alle
              Buttons direkt aufs Instagram-Profil.
            </p>
            <div class="insta-fallback-actions">
              <a class="btn btn-primary" href={company.instagramUrl} target="_blank" rel="noopener">
                Auf Instagram ansehen
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M7 17 L17 7 M9 7 H17 V15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a class="btn btn-ghost" href="https://behold.so" target="_blank" rel="noopener">
                Behold-Setup öffnen
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
            <p class="insta-fallback-hint">
              In <code>README.md</code> ist die Schritt-für-Schritt-Anleitung dokumentiert.
            </p>
          </div>
        </div>
      </div>
    )}

  </div>
</section>
