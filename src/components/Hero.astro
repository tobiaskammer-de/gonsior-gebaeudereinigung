---
import { company } from '../data/site.js';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="hero" id="top">
  <div class="shell hero-shell">

    <div class="hero-text">
      <div class="hero-eyebrow">
        <span class="dot" aria-hidden="true"></span>
        <span>Inhabergeführt · {company.city}-{company.district}</span>
      </div>

      <h1 class="hero-headline">
        <span class="hl-line">Sauberkeit,</span>
        <span class="hl-line hl-emphasis">mit Handschlag.</span>
      </h1>

      <p class="hero-lede">
        Glas-, Unterhalts- und Treppenhausreinigung in {company.city} und
        Umgebung — gemacht von Menschen, die pünktlich kommen, gründlich
        arbeiten und sich beim Namen vorstellen.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#kontakt">
          Kostenfreies Angebot
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="btn btn-ghost" href={`tel:${company.phoneIntl}`}>
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M5 4h3l2 5-2 1a11 11 0 006 6l1-2 5 2v3a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
          {company.phone}
        </a>
      </div>
    </div>

    <figure class="hero-figure" aria-hidden="true">
      <img src={`${base}/assets/hero-room.jpg`} alt="" loading="eager" fetchpriority="high" width="1800" height="1158" />
      <figcaption class="hero-caption">
        <span class="caption-key">Glasflächen</span>
        <span class="caption-val">streifenfrei, rahmenrein</span>
      </figcaption>
    </figure>

  </div>

  <div class="shell">
    <ul class="hero-meta" aria-label="Vertrauenssignale">
      <li>
        <span class="meta-num">14</span>
        <span class="meta-label">Tage Reaktionsgarantie aufs Angebot</span>
      </li>
      <li>
        <span class="meta-num">100%</span>
        <span class="meta-label">Inhabergeführt, kein Subunternehmer</span>
      </li>
      <li>
        <span class="meta-num">HWK</span>
        <span class="meta-label">Mitglied der Handwerks&shy;kammer Düsseldorf</span>
      </li>
    </ul>
  </div>

  <div class="hero-marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>Hausverwaltungen</span><span>•</span>
      <span>Gewerbe</span><span>•</span>
      <span>Privat</span><span>•</span>
      <span>WEG</span><span>•</span>
      <span>Praxen</span><span>•</span>
      <span>Kanzleien</span><span>•</span>
      <span>Ladenlokale</span><span>•</span>
      <span>Hausverwaltungen</span><span>•</span>
      <span>Gewerbe</span><span>•</span>
      <span>Privat</span><span>•</span>
      <span>WEG</span><span>•</span>
      <span>Praxen</span><span>•</span>
      <span>Kanzleien</span><span>•</span>
      <span>Ladenlokale</span><span>•</span>
    </div>
  </div>
</section>
