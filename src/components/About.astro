---
import { company } from '../data/site.js';
---
<section class="meister" id="meister">
  <div class="shell meister-shell">

    <div class="meister-text">
      <span class="kicker">§ 02 — Über uns</span>
      <h2 class="section-title">
        Ihr verlässlicher<br/>
        <em>Ansprechpartner.</em>
      </h2>
      <p class="prose">
        Gonsior Gebäudereinigung ist Ihr verlässlicher Ansprechpartner
        in allen Fragen rund um Hygiene und Sauberkeit — Gebäudereinigung
        im Innen- und Gebäudepflege im Außenbereich.
        Hinter dem Betrieb steht <strong>{company.ownerFirst} {company.ownerLast} persönlich</strong>:
        kein Callcenter, keine Subunternehmer.
      </p>
      <p class="prose">
        Beim ersten Termin schaue ich selbst vorbei, bespreche mit Ihnen
        die Räume und mache Ihnen ein klares, schriftliches Angebot.
        Was vereinbart ist, wird vereinbart eingehalten — pünktlich,
        gründlich und mit eigenem Material.
      </p>

      <ul class="badges" aria-label="Eckdaten">
        <li>
          <span class="badge-key">Inhaber</span>
          <span class="badge-val">{company.ownerFirst} {company.ownerLast}</span>
        </li>
        <li>
          <span class="badge-key">Mitglied</span>
          <span class="badge-val">Handwerks&shy;kammer Düsseldorf</span>
        </li>
        <li>
          <span class="badge-key">Sitz</span>
          <span class="badge-val">{company.street}, {company.zip} {company.city}</span>
        </li>
        <li>
          <span class="badge-key">Servicegebiet</span>
          <span class="badge-val">{company.city} und Umgebung — Ruhrgebiet</span>
        </li>
      </ul>
    </div>

    <aside class="meister-card" aria-label="Was Sie bekommen">
      <div class="card-tag">
        <span class="card-tag-dot" aria-hidden="true"></span>
        Was Sie bekommen
      </div>

      <ul class="meister-list">
        <li>
          <span class="ml-num">01</span>
          <div>
            <strong>Festen Ansprechpartner</strong>
            <span>Manuel Gonsior persönlich — vom ersten Anruf bis zur laufenden Reinigung.</span>
          </div>
        </li>
        <li>
          <span class="ml-num">02</span>
          <div>
            <strong>Vereinbarter Turnus</strong>
            <span>Wöchentlich, 14-tägig oder nach Bedarf — wir kommen, wenn wir es zugesagt haben.</span>
          </div>
        </li>
        <li>
          <span class="ml-num">03</span>
          <div>
            <strong>Eigenes Material</strong>
            <span>Profi-Ausstattung und passende Mittel — Sie müssen nichts bereitstellen.</span>
          </div>
        </li>
        <li>
          <span class="ml-num">04</span>
          <div>
            <strong>Schriftliches Angebot</strong>
            <span>Klar formuliert, ohne Kleingedrucktes — und ohne lange Vertragsbindung.</span>
          </div>
        </li>
      </ul>

      <a class="meister-cta" href={`tel:${company.phoneIntl}`}>
        Persönlich sprechen
        <span>{company.phone}</span>
      </a>
    </aside>

  </div>
</section>
