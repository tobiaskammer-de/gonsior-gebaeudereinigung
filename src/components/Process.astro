---
import { steps } from '../data/site.js';
---
<section class="ablauf" id="ablauf">
  <div class="shell">
    <header class="section-head section-head--center">
      <span class="kicker">§ 03 — Ablauf</span>
      <h2 class="section-title">So einfach läuft es ab.</h2>
      <p class="section-lede">
        Vom ersten Kontakt bis zur ersten Reinigung in drei Schritten —
        unkompliziert, persönlich und ohne langen Papierkram.
      </p>
    </header>

    <ol class="steps">
      {steps.map(s => (
        <li class="step">
          <span class="step-num">{s.num}</span>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-text">{s.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
