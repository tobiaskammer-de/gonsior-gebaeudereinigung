---
import { company, nav } from '../data/site.js';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="site-header" data-header>
  <div class="shell header-shell">
    <a class="brand" href="#top" aria-label={`${company.name} — Startseite`}>
      <img class="brand-mark" src={`${base}/assets/logo.jpg`} alt="" width="510" height="215" />
      <span class="brand-text">
        <span class="brand-name">{company.shortName}</span>
        <span class="brand-sub">Gebäudereinigung · {company.city}</span>
      </span>
    </a>
    <nav class="primary-nav" aria-label="Hauptnavigation">
      {nav.map(n => <a href={`#${n.id}`}>{n.label}</a>)}
    </nav>
    <a class="header-cta" href={`tel:${company.phoneIntl}`}>
      <span class="header-cta-label">Anrufen</span>
      <span class="header-cta-num">{company.phone}</span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Menü öffnen" data-nav-toggle>
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>
</header>

<dialog class="mobile-nav" id="mobile-nav" aria-label="Mobile Navigation">
  <div class="mobile-nav-inner">
    <div class="mobile-nav-head">
      <span class="kicker">Menü</span>
      <button class="mobile-nav-close" type="button" aria-label="Menü schließen" data-nav-close>
        <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
          <path d="M5 5 L19 19 M19 5 L5 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <ol class="mobile-nav-list">
      {nav.map((n, i) => (
        <li>
          <a href={`#${n.id}`} data-nav-link>
            <span class="mobile-nav-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="mobile-nav-label">{n.label}</span>
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M9 6 L15 12 L9 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </li>
      ))}
    </ol>

    <div class="mobile-nav-foot">
      <a class="btn btn-primary mobile-nav-call" href={`tel:${company.phoneIntl}`}>
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 4h3l2 5-2 1a11 11 0 006 6l1-2 5 2v3a2 2 0 01-2 2A16 16 0 013 6a2 2 0 012-2z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
        Jetzt anrufen — {company.phone}
      </a>
      <a class="btn btn-ghost mobile-nav-whatsapp" href={company.whatsappBase}>
        WhatsApp schreiben
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</dialog>
